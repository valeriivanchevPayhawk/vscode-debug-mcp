{
  "name": "vscode-debug-mcp",
  "displayName": "Debug MCP Bridge",
  "description": "Exposes the VS Code debugger (DAP) as an MCP server so Claude can set breakpoints, step, and inspect live runtime state.",
  "version": "0.1.0",
  "publisher": "payhawk",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debugMcp.start",
        "title": "Debug MCP: Start Server"
      },
      {
        "command": "debugMcp.stop",
        "title": "Debug MCP: Stop Server"
      },
      {
        "command": "debugMcp.copyClaudeCommand",
        "title": "Debug MCP: Copy 'claude mcp add' command"
      },
      {
        "command": "debugMcp.showStatus",
        "title": "Debug MCP: Show Status"
      }
    ],
    "configuration": {
      "title": "Debug MCP Bridge",
      "properties": {
        "debugMcp.port": {
          "type": "number",
          "default": 7345,
          "description": "Local TCP port the MCP HTTP server listens on (bound to 127.0.0.1)."
        },
        "debugMcp.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the MCP server automatically when VS Code launches."
        },
        "debugMcp.outputBufferLines": {
          "type": "number",
          "default": 2000,
          "description": "Maximum number of captured debug-console/stdout/stderr lines to retain per session."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.js --production",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "@vscode/vsce": "^3.2.0"
  }
}
